{
  "name": "search-text-action",
  "version": "0.1.0",
  "description": "Github action to search text in a response of a URL",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "lint": "eslint .",
    "prepare": "ncc build index.js -o dist --source-map --license licenses.txt",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "all": "npm run lint && npm run prepare && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/javalon/search-text-action.git"
  },
  "keywords": [
    "GitHub",
    "Actions",
    "JavaScript"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/javalon/search-text-action/issues"
  },
  "homepage": "https://github.com/javalon/search-text-action#readme",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "axios": "^1.18.1"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.4",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nock": "^13.5.6"
  }
}
